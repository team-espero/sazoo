{
  "name": "sazoo-v2.1-forest",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "build:prod": "vite build --mode production",
    "preview": "vite preview",
    "server:dev": "node --watch server/index.js",
    "server:start": "node server/index.js",
    "lint": "node scripts/lint-secrets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "quality": "npm run lint && npm run typecheck && npm run test && npm run build",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:android": "npm run build && npx cap sync android",
    "mobile:ios": "npm run build && npx cap sync ios",
    "mobile:version:patch": "node scripts/bump-android-version.mjs --kind patch",
    "mobile:version:minor": "node scripts/bump-android-version.mjs --kind minor",
    "mobile:version:major": "node scripts/bump-android-version.mjs --kind major",
    "mobile:release": "node scripts/build-android-release.mjs",
    "assets:store": "powershell -ExecutionPolicy Bypass -File scripts/generate-store-assets.ps1",
    "baseline:freeze": "node scripts/freeze-product-baseline.mjs",
    "qa:invite": "node scripts/qa-public-invite-flow.cjs",
    "qa:firebase": "node scripts/qa-firebase-analytics.cjs",
    "qa:firebase:flow": "node scripts/qa-firebase-analytics-flow.cjs",
    "qa:currency": "node scripts/qa-currency-chat.cjs",
    "qa:currency:rewards": "node scripts/qa-currency-rewards.cjs",
    "qa:memory:store": "node scripts/qa-memory-store.mjs",
    "qa:launch-db": "node scripts/qa-launch-db-state.mjs",
    "qa:gemini:live": "node scripts/qa-live-gemini.mjs",
    "ci:gemini": "node scripts/qa-live-gemini.mjs --strict",
    "seed:dev": "node scripts/seed-launch-data.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@neondatabase/serverless": "^1.0.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "firebase": "^12.10.0",
    "framer-motion": "11.18.2",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-error-boundary": "4.0.13",
    "three": "^0.182.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@capacitor/android": "^7.1.0",
    "@capacitor/cli": "^7.1.0",
    "@capacitor/core": "^7.1.0",
    "@capacitor/ios": "^7.1.0",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.58.2",
    "postcss": "^8.4.49",
    "rollup-plugin-visualizer": "^6.0.5",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^7.3.1",
    "vitest": "^2.1.9"
  }
}
