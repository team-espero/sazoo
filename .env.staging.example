# Frontend (staging)
VITE_APP_ENV=staging
VITE_API_BASE_URL=https://staging-api.example.com/api/v1
VITE_API_TIMEOUT_MS=12000

# Backend (staging)
NODE_ENV=production
PORT=8787
API_PREFIX=/api/v1
# Server-only Gemini configuration. Never expose these with a VITE_ prefix.
GEMINI_API_KEY=replace-with-staging-key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_INSIGHTS_MODEL=gemini-2.5-flash
CORS_ORIGINS=https://staging.example.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
LOG_LEVEL=info
