# Frontend (local development)
VITE_APP_ENV=dev
VITE_API_BASE_URL=http://localhost:8787/api/v1
VITE_API_TIMEOUT_MS=65000
VITE_FIREBASE_API_KEY=replace-with-firebase-web-key
VITE_FIREBASE_AUTH_DOMAIN=replace-with-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=replace-with-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=replace-with-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-with-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=replace-with-firebase-app-id

VITE_KAKAO_JAVASCRIPT_KEY=replace-with-kakao-javascript-key
VITE_KAKAO_REDIRECT_URI=

# Backend (local development)
NODE_ENV=development
PORT=8787
API_PREFIX=/api/v1
# Server-only Gemini configuration. Never expose these with a VITE_ prefix.
GEMINI_API_KEY=replace-with-real-server-key
KAKAO_REST_API_KEY=replace-with-kakao-rest-api-key
KAKAO_CLIENT_SECRET=
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_INSIGHTS_MODEL=gemini-2.5-flash-lite
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5180,http://127.0.0.1:5180
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
LOG_LEVEL=info

# Dashboard access control
DASHBOARD_ACCESS_KEY=replace-with-strong-dashboard-passcode
DASHBOARD_ALLOWED_EMAILS=
