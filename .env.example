# Frontend
VITE_APP_ENV=dev
VITE_API_BASE_URL=http://localhost:8787/api/v1
VITE_API_TIMEOUT_MS=12000

# Backend
NODE_ENV=development
PORT=8787
API_PREFIX=/api/v1
# Server-only Gemini configuration. Never expose these with a VITE_ prefix.
GEMINI_API_KEY=replace-with-real-server-key
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_INSIGHTS_MODEL=gemini-2.5-flash
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
LOG_LEVEL=info
